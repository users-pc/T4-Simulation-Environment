attr processid 30705
attr repetition 0
attr replication #0
attr resultdir results
attr runnumber 0
attr seedset 0
config image-path ../../inet-4.5.4/images
config network CustomAodvNetwork
config description "Custom AODV Router with socket communication"
config sim-time-limit 100s
config *.configurator.config "xml(\"<config>     <interface hosts='node1' names='wlan0' address='192.168.17.1' netmask='255.255.255.0'/>     <interface hosts='node2' names='wlan0' address='192.168.17.2' netmask='255.255.255.0'/>     <interface hosts='node3' names='wlan0' address='192.168.17.3' netmask='255.255.255.0'/>     <interface hosts='node4' names='wlan0' address='192.168.17.4' netmask='255.255.255.0'/>     <interface hosts='node5' names='wlan0' address='192.168.17.5' netmask='255.255.255.0'/> </config>\")"
config *.configurator.addStaticRoutes false
config *.configurator.dumpAddresses true
config *.configurator.dumpTopology true
config *.configurator.dumpRoutes true
config **.displayCommunicationRanges true
config **.transmitter.power 2mW
config *.node*.routing.typename Aodv
config *.node*.routing.activeRouteTimeout 3s
config *.node*.routing.helloInterval 1s
config *.node*.routing.netDiameter 35
config *.node*.routing.nodeTraversalTime 0.04s
config *.node*.routing.allowedHelloLoss 2
config *.node1.numCustomApps 1
config *.node1.customApp[0].typename CustomAodvApp
config *.node1.customApp[0].localPort 5000
config *.node1.customApp[0].destPort 5000
config *.node1.customApp[0].destAddress "\"node5\""
config *.node1.customApp[0].messageLength 512B
config *.node1.customApp[0].sendInterval 2s
config *.node1.customApp[0].startTime 5s
config *.node5.numCustomApps 1
config *.node5.customApp[0].typename CustomAodvApp
config *.node5.customApp[0].localPort 5000
config *.node5.customApp[0].destAddress "\"\""
config *.node2.numCustomApps 0
config *.node3.numCustomApps 0
config *.node4.numCustomApps 0
config *.visualizer.*.routingTableVisualizer.displayRoutingTables true
config *.visualizer.*.routingTableVisualizer.displayRoutesIndividually false
config *.visualizer.*.networkRouteVisualizer.displayRoutes true
config **.routingTable.netmaskRoutes "\"\""
config *.visualizer.*.interfaceTableVisualizer.displayInterfaceTables true
config *.visualizer.*.interfaceTableVisualizer.interfaceFilter "\"not(lo*)\""
config *.visualizer.*.interfaceTableVisualizer.nodeFilter "\"not(*switch*)\""
config *.visualizer.*.interfaceTableVisualizer.displayWiredInterfacesAtConnections false
config *.visualizer.*.interfaceTableVisualizer.format "\"%N %n\""

