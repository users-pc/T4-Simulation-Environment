config image-path ../../inet-4.5.4/images
config network RoutingTableVisualizationDynamicShowcase
config description "Visualizing changing routing tables"
config *.configurator.dumpAddresses true
config *.configurator.dumpTopology true
config *.configurator.dumpLinks true
config *.configurator.dumpRoutes true
config *.visualizer.*.routingTableVisualizer.destinationFilter "\"destinationHost\""
config *.visualizer.*.routingTableVisualizer.displayRoutingTables true
config *.visualizer.*.interfaceTableVisualizer.displayInterfaceTables false
config *.destinationHost.mobility.typename LinearMobility
config *.*.mobility.speed 10mps
config *.destinationHost.mobility.initialMovementHeading 90deg
config *.*.mobility.constraintAreaMinY 0m
config *.*.mobility.constraintAreaMaxY 600m
config *.visualizer.*.mobilityVisualizer.animationSpeed 0.1
config *.sourceHost.numApps 1
config *.sourceHost.app[0].typename PingApp
config *.sourceHost.app[*].destAddr "\"destinationHost\""
config **.displayCommunicationRanges true
config **.transmitter.power 1mW
config *.configurator.addStaticRoutes false
config **.routingTable.netmaskRoutes "\"\""
config *.visualizer.*.interfaceTableVisualizer.displayInterfaceTables true
config *.visualizer.*.interfaceTableVisualizer.interfaceFilter "\"not(lo*)\""
config *.visualizer.*.interfaceTableVisualizer.nodeFilter "\"not(*switch*)\""
config *.visualizer.*.interfaceTableVisualizer.displayWiredInterfacesAtConnections false
config *.visualizer.*.interfaceTableVisualizer.format "\"%N %n\""

